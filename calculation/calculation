h = 6.62607015e-34 # プランク定数（Js単位）
c = 2.99792458e8  # 真空中の光速度（m/s単位）
e = 1.602176634e-19 # 素電荷（C単位）
print("{0} eV = {1:.3e} J".format(1, e))
print("{0} eV = {1} cm-1".format(1, e/(h*c)/1e2))


# エネルギーeV → 波長nm, 下のeV_1の値を書き換えて変換
eV_1 = 5.370
C_1 = eV_1 * e #単位をクーロンに
print("{0} eV = {1} nm".format(eV_1, ((h*c)/C_1)*1e9))


# 波長nm → エネルギーeV, 下のnmの値を書き換えて変換
nm = 238.5
cm_1 = 1 / nm *1e7
eV = cm_1 / (e/(h*c)/1e2)
print("{0} nm = {1} eV".format(nm, eV))